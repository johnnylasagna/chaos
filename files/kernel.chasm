LABEL calls
    JMP kernel
    JMP print
    JMP read
    JMP write
    JMP copy

LABEL print
    RET

LABEL read
    RET

LABEL write
    RET

LABEL copy
    RET

LABEL kernel
    MOVI B 0

LABEL animate
    MOVI A 4096
    MOVI C 480000
    CALL drawloop
    ADDI B B 128
    JMP animate

LABEL drawloop
    STORE8 A B
    SUBI C C 1
    ADDI A A 1
    CMPI C 0
    JNE drawloop
    RET

HALT