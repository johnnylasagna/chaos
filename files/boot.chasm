// Disk address
MOVI B 0x200

// Memory address
MOVI C 0x200

// Number of bytes
MOVI D 0x200

SYS_READ

MOVSTR E greeting

MOVI A 1

MOVI C 300
MOVI D 300

LABEL print
    LOAD8 B E
    CMPI B 0
    JE kernel
    SYS
    ADDI E E 1
    ADDI C C 16
    JMP print

LABEL kernel

MOVI A 0

SYS

STRING greeting Booting Chaos\0
STRING secret The Modern Age